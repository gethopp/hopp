# Hopp self-hosted — environment variables
#
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Only DOMAIN is strictly required. All secrets should be generated.
# ============================================================

# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------

# Your public domain (no protocol, no trailing slash)
# Example: hopp.example.com
DOMAIN=hopp.example.com

# ------------------------------------------------------------
# AUTO-GENERATED (run these once and paste the output)
# ------------------------------------------------------------

# Session secret for cookie sessions.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# LiveKit API key and secret for WebRTC signaling.
# Generate with: openssl rand -base64 32
LIVEKIT_API_KEY=
# Generate with: openssl rand -base64 64
LIVEKIT_API_SECRET=

# LiveKit server URL the clients connect to.
# Default (when unset): wss://livekit.${DOMAIN} — Caddy proxies this to the bundled LiveKit container.
# Set explicitly when:
#   - using LiveKit Cloud: wss://your-project.livekit.cloud
#   - testing locally without TLS: ws://localhost:7880
LIVEKIT_SERVER_URL=

# PostgreSQL password (change from default for production).
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=

# ------------------------------------------------------------
# OPTIONAL — Email (disabled when unset)
# ------------------------------------------------------------

# Resend API key for sending real emails.
# Get one at: https://resend.com
RESEND_API_KEY=

# Default "from" address for outgoing emails.
RESEND_DEFAULT_SENDER=

# ------------------------------------------------------------
# OPTIONAL — OAuth providers (auto-disabled when empty)
# ------------------------------------------------------------

# Google OAuth
GOOGLE_KEY=
GOOGLE_SECRET=

# Slack OAuth
SLACK_KEY=
SLACK_SECRET=

# GitHub OAuth
GITHUB_KEY=
GITHUB_SECRET=

# ------------------------------------------------------------
# OPTIONAL — Slack App (slash command integration)
# ------------------------------------------------------------

SLACK_APP_CLIENT_ID=
SLACK_APP_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_TOKEN_ENCRYPTION_KEY=

# ------------------------------------------------------------
# OPTIONAL — Integrations
# ------------------------------------------------------------

# Sentry error tracking
SENTRY_DSN=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAID_PRICE_ID=
STRIPE_PAID_YEARLY_PRICE_ID=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# OPTIONAL — Advanced
# ------------------------------------------------------------

# Docker image tag (default: latest). Pin to a version for stability.
# Example: HOPP_VERSION=v0.0.33
HOPP_VERSION=
